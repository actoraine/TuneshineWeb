{
  "name": "tuneshine-web-console",
  "version": "1.0.0",
  "description": "Local single-page app to control a Tuneshine device via HTTP API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "NODE_ENV=development node src/backend/server.js",
    "test": "vitest run --coverage",
    "test:backend": "vitest run tests/backend --coverage",
    "test:frontend": "vitest run tests/frontend --coverage",
    "test:all": "node scripts/run-tests.mjs",
    "coverage:check": "node scripts/check-coverage.mjs",
    "audit": "npm audit --omit=dev"
  },
  "keywords": [
    "tuneshine",
    "nodejs",
    "spa",
    "openapi"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
